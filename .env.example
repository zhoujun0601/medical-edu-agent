# ==============================================
# 医学教育智能体服务 - 环境配置
# ==============================================

# --- LLM 后端配置 ---
# 支持: anthropic | openai | openai_compatible
LLM_PROVIDER=anthropic

# Anthropic 配置
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI / 兼容接口配置（如 Ollama, vLLM, DeepSeek, 智谱 等）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- 服务配置 ---
HOST=0.0.0.0
PORT=8000
WORKERS=1
DEBUG=false

# --- 安全配置 ---
# API 访问密钥（Open WebUI / LibreChat 连接时填写）
SERVICE_API_KEY=med-edu-secret-key-change-me
# 是否启用 API Key 验证（false 则不验证，方便本地开发）
ENABLE_API_KEY_AUTH=true

# JWT 配置（可选）
SECRET_KEY=your-jwt-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- 智能体配置 ---
# 默认智能体模式: general | clinical | pharmacology | anatomy | exam | diagnosis
DEFAULT_AGENT_MODE=general
# 最大 Token 上下文
MAX_CONTEXT_TOKENS=100000
# 最大输出 Token
MAX_OUTPUT_TOKENS=4096

# --- 功能开关 ---
ENABLE_STREAMING=true
ENABLE_FUNCTION_CALLING=true
ENABLE_USAGE_LOGGING=true
ENABLE_RATE_LIMITING=true

# 速率限制（每分钟请求数，0=不限制）
RATE_LIMIT_PER_MINUTE=60

# --- 日志配置 ---
LOG_LEVEL=INFO
LOG_FILE=logs/medical_edu_agent.log
